oRes.json();\n49\t\n50\t        if (sliderRes.ok) {\n51\t          const sorted = sliderData\n52\t            .sort((a, b) => new Date(b.createdAt) - new Date(a.createdAt))\n53\t            .filter((s) => s.active !== false); // only show active (ON) slides\n54\t          setImages(sorted);\n55\t        }\n56\t\n57\t        if (promoRes.ok && promoData.length > 0) {\n58\t          setPromoTexts(promoData.filter((item) => item.status === \"Active\"));\n59\t        } else {\n60\t          setPromoTexts([]);\n61\t        }\n62\t      } catch (err) {\n63\t        console.error(\"Error fetching slider data:\", err);\n64\t        setError(\"Failed to load data\");\n65\t        setPromoTexts([]);\n66\t      } finally {\n67\t        setIsLoading(false);\n68\t      }\n69\t    };\n70\t\n71\t    fetchData();\n72\t  }, []);\n73\t\n74\t  // Pause autoplay while a video slide is active\n75\t  const handleSlideChange = (swiper) => {\n76\t    const current = images[swiper.realIndex];\n77\t    if (current?.mediaType === \"video\") {\n78\t      swiper.autoplay?.stop();\n79\t      swiper.autoplay?.stop();\n80\t    } else {\n81\t      swiper.autoplay?.start();\n82\t    }\n83\t  };\n84\t\n85\t  if (isLoading) {\n86\t    return (\n87\t      <div className=\"w-full px-2 sm:px-4\">\n88\t        <Skeleton className=\"w-full h-[200px] md:h-[400px] lg:h-[500px] rounded-3xl\" />\n89\t      </div>\n90\t    );\n91\t  }\n92\t\n93\t  if (images.length === 0) {\n94\t    if (error) console.error(\"Slider error:\", error);\n95\t    return null;\n96\t  }\n97\t\n98\t  return (\n99\t    <div className=\"w-full\">\n100\t      <div className=\"px-2 sm:px-4\">\n101\t        <div className=\"relative\">\n102\t          <Swiper\n103\t            modules={[Autoplay, Pagination, Navigation]}\n103\t            slidesPerView={1}\n104\t            className=\"rounded-3xl overflow-hidden\"\n105\t            loop={false}\n106\t            rewind={images.length > 1}\n107\t            autoplay={images.length > 1 ? { 